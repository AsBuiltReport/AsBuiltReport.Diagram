{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "PowerShell: Interactive Session",
            "type": "PowerShell",
            "request": "launch"
        },
        {
            "name": "PowerShell cmdlets: AbrDiagrammer",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Debug AbrDiagrammer",
            "program": "pwsh",
            "args": [
                "-NoExit",
                "-NoProfile",
                "-Command",
                "import-module ./Sources/Diagrammer/bin/Debug/net8.0/AbrDiagrammer.dll",
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": "PowerShell cmdlets: AbrDiaConvertImageToPDF",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Debug AbrDiaConvertImageToPDF",
            "program": "powershell",
            "args": [
                "-NoExit",
                "-NoProfile",
                "-Command",
                "import-module ./Sources/DiaConvertImageToPDF/bin/Debug/net48/AbrDiaConvertImageToPDF.dll",
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
    ]
}